        A.name,
        A.app_website,
        A.platform_id,
        A.industry_id,
        A.scene_id,
        A.platform_history_id,
        A.publish_url,
        A.editor_url,
        A.visit_url,
        A.image_url,
        A.assets_url,
        A.state,
        A.published,
