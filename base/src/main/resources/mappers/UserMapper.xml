<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tinyengine.it.mapper.UserMapper">

    <!-- 通用设置 -->

    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        id
        , username, password, email, salt, public_key, private_key, enable, created_time, last_updated_time,
        is_admin, is_public
    </sql>

    <!-- 通用条件列 -->
    <sql id="UserByCondition">
        <if test="username!=null and username!=''">
            AND username = #{username}
        </if>
        <if test="password!=null and password!=''">
            AND password = #{password}
        </if>
        <if test="email!=null and email!=''">
            AND email = #{email}
        </if>
        <if test="salt!=null and salt!=''">
            AND salt = #{salt}
        </if>
        <if test="publicKey!=null and publicKey!=''">
            AND public_key = #{publicKey}
        </if>
        <if test="privateKey!=null and privateKey!=''">
            AND private_key = #{privateKey}
        </if>
        <if test="isEnable!=null">
            AND enable = #{isEnable}
        </if>
        <if test="createdTime!=null">
            AND created_time = #{createdTime}
        </if>
        <if test="lastUpdatedTime!=null">
            AND last_updated_time = #{lastUpdatedTime}
        </if>
        <if test="isAdmin!=null">
            AND is_admin = #{isAdmin}
        </if>
        <if test="isPublic!=null">
            AND is_public = #{isPublic}
        </if>
    </sql>

    <!-- 通用设置列 -->
    <sql id="UserSetColumns">
        <if test="username!=null and username!=''">
            username = #{username},
        </if>
        <if test="password!=null and password!=''">
            password = #{password},
        </if>
        <if test="email!=null and email!=''">
            email = #{email},
        </if>
        <if test="salt!=null and salt!=''">
            salt = #{salt},
        </if>
        <if test="isEnable!=null">
            enable = #{isEnable},
        </if>
        <if test="createdTime!=null">
            created_time = #{createdTime},
        </if>
        <if test="lastUpdatedTime!=null">
            last_updated_time = #{lastUpdatedTime},
        </if>
        <if test="isAdmin!=null">
            is_admin = #{isAdmin},
        </if>
        <if test="isPublic!=null">
            is_public = #{isPublic},
        </if>
    </sql>


    <!-- 通用查询映射结果 -->
    <resultMap id="UserMap" type="com.tinyengine.it.model.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="email" property="email"/>
        <result column="public_key" property="publicKey"/>
        <result column="private_key" property="privateKey"/>
        <result column="enable" property="isEnable"/>
        <result column="created_time" property="createdTime"/>
        <result column="last_updated_time" property="lastUpdatedTime"/>
        <result column="is_admin" property="isAdmin"/>
        <result column="is_public" property="isPublic"/>
    </resultMap>

    <!-- 查询表t_user所有数据 -->
    <select id="queryAllUser" resultMap="UserMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_user
    </select>

    <!-- 根据主键id查询表t_user信息 -->
    <select id="queryUserById" resultMap="UserMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_user
        WHERE id=#{id}
    </select>

    <!-- 根据ids范围内的查询表t_user数据 -->
    <select id="selectUsersByIds" parameterType="java.util.List" resultMap="UserMap">
        SELECT id, username
        FROM t_user
        WHERE id IN
        <foreach collection="ids" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </select>

    <!-- 根据条件查询表t_user数据 -->
    <select id="queryUserByCondition" resultMap="UserMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_user
        WHERE 1=1
        <include refid="UserByCondition"/>
    </select>

    <!-- 根据主键id删除表t_user数据 -->
    <delete id="deleteUserById">
        DELETE
        FROM t_user
        WHERE id = #{id}
    </delete>

    <!-- 根据主键id更新表t_user数据 -->
    <update id="updateUserById" parameterType="com.tinyengine.it.model.entity.User">
        UPDATE t_user
        <set>
            <include refid="UserSetColumns"/>
        </set>
        WHERE
        id=#{id}
    </update>

    <insert id="createUser" useGeneratedKeys="true" keyProperty="id"
            parameterType="com.tinyengine.it.model.entity.User">
        INSERT INTO t_user ( id
        , username
        , password
        , email
        , salt
        , public_key
        , private_key
        , enable
        , created_time
        , last_updated_time
        , is_admin
        , is_public)
        VALUES ( #{id}
        , #{username}
        , #{password}
        , #{email}
        , #{salt}
        , #{publicKey}
        , #{privateKey}
        , #{isEnable}
        , #{createdTime}
        , #{lastUpdatedTime}
        , #{isAdmin}
        , #{isPublic})
    </insert>
</mapper>
